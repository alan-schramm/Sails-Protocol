generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  BTC
  USDT_ERC20
  USDT_TRC20
  USDT_LIQUID
  USDT_LIGHTNING
  LN_BTC
  LIQUID_BTC
  SPARK
  STACKS
  RSK_BTC
}

enum TradeSide {
  BUY
  SELL
}

enum OfferStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum TradeStatus {
  PENDING
  ACTIVE
  COMPLETED
  DISPUTED
  CANCELLED
}

enum EscrowType {
  MULTISIG
  LIGHTNING_HODL
  LIQUID_COVENANT
  WDK_USDT_EVM // real @tetherto/wdk-wallet-evm USDT (ERC-20) settlement — see wdk-settlement.provider.ts
  MOCK
}

enum EscrowStatus {
  CREATED
  FUNDS_LOCKED
  PAYMENT_PENDING
  COMPLETED
  DISPUTED
  REFUNDED
}

enum PaymentMethod {
  PIX
  TED
  BANK_TRANSFER
  CRYPTO_DIRECT
  LIGHTNING_DIRECT
  CASH
  OTHER
}

// moduleId/protocolVersion below: mandated by MASTER_COORDINATION.md so that
// future modules (Sails OpenFinance, Sails OpenAgents) can coexist in the
// same tables without ambiguity about which module owns which row, and so
// the protocol version an entity was created under is always traceable.

model User {
  id              String   @id @default(uuid())
  publicKey       String   @unique
  displayName     String?
  peerId          String?  @unique
  reputationScore Float    @default(0)
  totalTrades     Int      @default(0)
  disputeCount    Int      @default(0)
  totalVolumeBtc  Decimal  @default(0) @db.Decimal(24, 8)
  verified        Boolean  @default(false)
  moduleId        String   @default("openidentity")
  protocolVersion String   @default("0.1")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  offers             Offer[]
  buyerTrades        Trade[]           @relation("BuyerTrades")
  sellerTrades       Trade[]           @relation("SellerTrades")
  sentMessages       Message[]
  reputationGiven    ReputationEvent[] @relation("RaterEvents")
  reputationReceived ReputationEvent[] @relation("RatedEvents")

  @@map("users")
}

model Offer {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  asset          AssetType
  side           TradeSide
  priceUsd       Decimal       @db.Decimal(24, 8)
  priceBrl       Decimal?      @db.Decimal(24, 8)
  minAmount      Decimal       @db.Decimal(24, 8)
  maxAmount      Decimal       @db.Decimal(24, 8)
  paymentMethod  PaymentMethod
  paymentDetails String?
  status         OfferStatus   @default(ACTIVE)
  network        String?
  description    String?
  requiresKyc    Boolean       @default(false)
  moduleId       String        @default("openliquidity")
  protocolVersion String       @default("0.1")
  intentType     String?
  // RFC-018 (rfcs/RFC-018-intent-as-canonical-trade-entry-point.md) —
  // the real Intent row this Offer was created from (createOffer() ->
  // intentEngine.create()). Nullable: pre-migration Offer rows have no
  // Intent behind them and remain fully valid, same backward-compatible
  // pattern RFC-008 used for entryHash/prevHash.
  intentId       String?
  intent         Intent?       @relation(fields: [intentId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  trades Trade[]

  @@index([asset, side, status])
  @@index([userId])
  @@map("offers")
}

model Trade {
  id          String      @id @default(uuid())
  offerId     String
  offer       Offer       @relation(fields: [offerId], references: [id])
  buyerId     String
  buyer       User        @relation("BuyerTrades", fields: [buyerId], references: [id])
  sellerId    String
  seller      User        @relation("SellerTrades", fields: [sellerId], references: [id])
  asset       AssetType
  amount      Decimal     @db.Decimal(24, 8)
  priceUsd    Decimal     @db.Decimal(24, 8)
  totalUsd    Decimal     @db.Decimal(24, 8)
  status      TradeStatus @default(PENDING)
  escrowId    String?     @unique
  escrow      Escrow?
  network     String?
  moduleId    String      @default("openp2p")
  protocolVersion String  @default("0.1")
  intentType  String      @default("TradeIntent")
  // RFC-018 — copied from the accepted Offer's intentId at trade
  // creation (createTrade()). Nullable, same rationale as Offer.intentId
  // above.
  intentId    String?
  intent      Intent?     @relation(fields: [intentId], references: [id])
  completedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  messages         Message[]
  reputationEvents ReputationEvent[]
  disputes         Dispute[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("trades")
}

model Escrow {
  id           String       @id @default(uuid())
  tradeId      String       @unique
  trade        Trade        @relation(fields: [tradeId], references: [id])
  type         EscrowType   @default(MOCK)
  status       EscrowStatus @default(CREATED)
  lockedAmount Decimal      @db.Decimal(24, 8)
  asset        AssetType
  network      String?
  multisigAddr String?
  redeemScript String?
  txLockId     String?
  txReleaseId  String?
  timelockHours Int         @default(24)
  moduleId     String       @default("opensettlement")
  protocolVersion String    @default("0.1")
  lockedAt     DateTime?
  expiresAt    DateTime?
  releasedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  events   EscrowEvent[]
  disputes Dispute[]

  @@map("escrows")
}

// Dispute primitive — PROTOCOL_SPECIFICATION.md §1.9. First real
// implementation (04-Deepseek Review.md's raiseDispute()/resolveDispute()
// task) — the primitive itself isn't new, only its persistence.
// resolution maps directly to escrow release/refund: RELEASE -> buyer
// wins (asset released to them), REFUND -> seller wins (asset returned).
enum DisputeStatus {
  OPENED
  EVIDENCE_SUBMITTED
  ARBITRATED
  RESOLVED
}

enum DisputeRuling {
  RELEASE // buyer wins — "dispute_resolved_buyer"
  REFUND  // seller wins — "dispute_resolved_seller"
  SPLIT   // §1.9's third option — no direct buyer/seller equivalent, kept as-is
}

model Dispute {
  id         String         @id @default(uuid())
  tradeId    String
  trade      Trade          @relation(fields: [tradeId], references: [id])
  escrowId   String
  escrow     Escrow         @relation(fields: [escrowId], references: [id])
  openedBy   String         // participantId who raised the dispute
  reason     String
  evidence   Json           @default("[]") // array of evidence descriptors
  arbiterId  String?        // populated by ArbitrationProvider.assign()
  status     DisputeStatus  @default(OPENED)
  ruling     DisputeRuling?
  resolvedAt DateTime?
  moduleId   String         @default("opensettlement")
  protocolVersion String    @default("0.1")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([tradeId])
  @@index([escrowId])
  @@index([status])
  @@map("disputes")
}

model EscrowEvent {
  id          String       @id @default(uuid())
  escrowId    String
  escrow      Escrow       @relation(fields: [escrowId], references: [id])
  fromStatus  EscrowStatus
  toStatus    EscrowStatus
  triggeredBy String
  note        String?
  createdAt   DateTime     @default(now())

  @@map("escrow_events")
}

// Intent persistence — PROTOCOL_SPECIFICATION.md §2 (Intent Engine), §2.6.
// Was "not yet implemented" per that section; this is the first real
// implementation, built for the MVP happy path (03-implementation_plan.md,
// approved by CISO + CTO).
model Intent {
  id             String    @id @default(uuid())
  type           String    // IntentType (common/types/intent.ts)
  version        String    @default("1.0")
  participantId  String
  agentId        String?
  parentIntentId String?
  moduleId       String
  payload        Json
  status         String    // IntentStatus (core/state-machine.ts)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  expiresAt      DateTime?
  fulfilledBy    String?
  metadata       Json      @default("{}")

  events IntentEvent[]
  // RFC-018 — back-relations for Offer.intentId/Trade.intentId above.
  // In practice one Intent maps to at most one Offer and one Trade
  // (TradeIntentPayload's current scope), but modeled as arrays since
  // that's the FK direction Prisma requires, not a claim that more than
  // one of each is expected.
  offers Offer[]
  trades Trade[]

  @@index([participantId])
  @@index([status])
  @@map("intents")
}

// IntentEvent is Intent's own audit trail — the same per-module-owned-table
// pattern EscrowEvent/ReputationEvent already established, not a second
// "Timeline" table (RFC-008 D5 already rejected a dedicated Timeline table
// in favor of per-module event tables Timeline projects over — this is one
// more of those, not a competing design). entryHash/prevHash are RFC-008
// D2's hash-chaining design (rfcs/RFC-008-verifiable-timestamps-and-chained-timeline.md)
// implemented here first — EscrowEvent/ReputationEvent still don't have it
// (BACKLOG.md: 🔲 Not started), this table picks that design up rather than
// inventing an unlinked event log the same gap RFC-008 already diagnosed.
model IntentEvent {
  id          String   @id @default(uuid())
  intentId    String
  intent      Intent   @relation(fields: [intentId], references: [id])
  fromStatus  String?
  toStatus    String
  triggeredBy String
  note        String?
  createdAt   DateTime @default(now())
  entryHash   String?  // sha256(fromStatus+toStatus+triggeredBy+prevHash), computed at write time
  prevHash    String?  // prior IntentEvent.entryHash for this intentId; 'genesis' for the first

  @@index([intentId])
  @@map("intent_events")
}

model Message {
  id        String   @id @default(uuid())
  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  msgType   String   @default("TEXT")
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tradeId])
  @@map("messages")
}

model ReputationEvent {
  id        String   @id @default(uuid())
  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id])
  raterId   String
  rater     User     @relation("RaterEvents", fields: [raterId], references: [id])
  ratedId   String
  rated     User     @relation("RatedEvents", fields: [ratedId], references: [id])
  score     Int
  comment   String?
  moduleId  String   @default("openreputation")
  protocolVersion String @default("0.1")
  createdAt DateTime @default(now())

  @@unique([tradeId, raterId])
  @@map("reputation_events")
}

// Capability Registry — PROTOCOL_SPECIFICATION.md §1.10,
// rfcs/RFC-005-capability-model.md (CapabilityGrant shape),
// rfcs/RFC-013-capability-registry-and-wallet-adapter.md (this table,
// first real persistence — core/capability-registry.ts was a stub with
// no table before this). Only CapabilityGrant (the permission side) is
// persisted here; Capability/CapabilityImplementation (the static
// moduleId <-> capabilityName mapping, RFC-005's own illustrative table)
// stays an in-code map in capability-registry.ts, per that RFC's
// Alternatives Considered — no real write path exists for it yet.
model CapabilityGrant {
  id             String    @id @default(uuid())
  grantedTo      String    // a Participant or Agent id (RFC-001)
  capabilityName String    // e.g. 'trade-coordination' (RFC-005's table)
  scope          String[]  // subset of that capability's events/API
  constraints    Json?     // e.g. { maxValue, expiresAt }
  issuedBy       String
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([grantedTo])
  @@index([capabilityName])
  @@map("capability_grants")
}

// Two-Person Control for Escrow Release — rfcs/RFC-015-dual-authorization-escrow-release.md.
// Application-layer maker-checker control, NOT on-chain multisig: WDK's
// real package (@tetherto/wdk-wallet-evm-erc-4337) is single-owner-only
// (checked against its actual compiled types before choosing this design,
// see that RFC's Motivation) — one seed still signs the eventual transfer.
// What this table adds is a real, persisted gate *before* that seed is
// ever asked to sign: both of a trade's own two counterparties
// (Trade.buyerId, Trade.sellerId) must independently record approval
// before escrow.service.ts's releaseFunds() will proceed on the normal
// (non-disputed) path. Arbitrated releases (Escrow.status === 'DISPUTED')
// intentionally bypass this — see that RFC's Decision §3.
model EscrowReleaseApproval {
  id         String   @id @default(uuid())
  escrowId   String
  approverId String   // must equal the trade's buyerId or sellerId — enforced in escrow.service.ts, not by a DB constraint
  approvedAt DateTime @default(now())

  @@unique([escrowId, approverId])
  @@index([escrowId])
  @@map("escrow_release_approvals")
}
