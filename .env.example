# Sails Protocol — Satsails Reference Implementation
# Copy to .env and fill in real values for local development.
# Every variable here is read in src/config/index.ts — that file is the
# single source of truth if this list and the code ever disagree.

# ── Database / Cache ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/sails_protocol
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Auth (RED_TEAM_REVIEW.md RT-002) ───────────────────────────────────────
AUTH_CHALLENGE_TTL=120
AUTH_SESSION_TTL=3600

# ── P2P Transport (Pears/HyperDHT) ─────────────────────────────────────────
# Comma-separated host:port pairs. Empty uses the public HyperDHT default.
HYPERDHT_BOOTSTRAP=

# ── Rate Limiting (THREAT_MODEL.md — previously unmitigated, real as of
# @fastify/rate-limit) ──────────────────────────────────────────────────────
# General ceiling, every route, per IP.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
# Tighter, independently-tracked ceiling on /v1/identity/challenge and
# /v1/identity/authenticate specifically (RED_TEAM_REVIEW.md RT-002) — a
# credential-stuffing attempt hits these two, not the general API.
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=1 minute

# ── Settlement (RED_TEAM_REVIEW.md RT-001 — read that before touching this) ─
# Refuses to boot in production unless MOCK_ESCROW/MOCK_SETTLEMENT are
# explicitly "false" once a real SettlementProvider exists.
MOCK_ESCROW=true
MOCK_SETTLEMENT=true
DEFAULT_TIMELOCK_HOURS=24

# Gates common/events/handlers.ts's automatic reaction to
# openp2p.trade.created -> settlement-orchestrator.ts's executeSettlement()
# (creates escrow, locks funds, emulates PIX receipt, releases real signed
# USDT once WDK_SEED_PHRASE is configured). Default false: this event
# fires for every real trade in this codebase, not only agent-driven demo
# trades, so unconditional auto-release would silently bypass the
# negotiation/dispute-window design. Leave false unless you specifically
# want fully autonomous settlement on every match.
AUTO_SETTLE_ON_MATCH=false

# ── OpenSettlement — Dispute Arbitration (RFC-007 D4) ──────────────────────
# Comma-separated participantIds this deployment trusts to arbitrate
# disputes. Empty means the dispute-resolution routes are unavailable
# until this is set — a reference deployment with no disputes yet is a
# valid state, not a boot failure.
TRUSTED_ARBITRATORS=

# ── OpenSettlement — WDK_USDT_EVM provider (wdk-settlement.provider.ts) ────
# Real @tetherto/wdk-wallet-evm calls. TESTNET ONLY — never point this at
# a mainnet RPC or a real USDT contract; MOCK_ESCROW=true (above) already
# keeps this provider inert by default even if these are set. A BIP-39
# seed phrase controls the treasury account AND every per-trade escrow
# sub-account (single-seed, two-hop escrow — see that file's own doc
# comment for the honest custody-model caveat). Leave WDK_SEED_PHRASE
# empty to keep this provider disabled.
WDK_SEED_PHRASE=
WDK_RPC_URL=https://sepolia.drpc.org
WDK_USDT_CONTRACT=

# ── OpenAgents — QVAC agent provider (qvac-agent.provider.ts) ──────────────
# No config needed — @qvac/sdk runs a local LLM (llama.cpp, GPU-accelerated
# via Vulkan/Metal) with no API key or cloud dependency. First call
# downloads the model (~737MB, cached locally after). Requires a GPU with
# a working Vulkan (Windows/Linux) or Metal (macOS) driver — see
# https://docs.qvac.tether.io/installation for platform requirements.
